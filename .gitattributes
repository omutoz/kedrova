* text=auto

# Web text files: keep LF in repo
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.svg   text eol=lf
*.md    text eol=lf

# Shell / config
*.sh    text eol=lf
*.py    text eol=lf

# Windows-specific scripts
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets: never modify line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.mp3   binary
*.wav   binary
*.ogg   binary
*.mp4   binary
*.webm  binary
*.pdf   binary
*.zip   binary